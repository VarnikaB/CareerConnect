# Application
FLASK_CONFIG=development        # development | production | testing
SECRET_KEY=your-secret-key-here # Required in production; auto-generated in dev

# Database
DATABASE_URL=sqlite:///instance/careerconnect.db  # Required in production (use postgresql://)

# Pagination
POSTS_PER_PAGE=10

# Admin
ADMIN_PASSWORD=change-me        # Password for the seeded ADMIN_USER

# Rate Limiting
RATELIMIT_STORAGE_URI=memory:// # Use redis://localhost:6379 in production
