{
  "uid": "careerconnect-overview",
  "title": "CareerConnect Overview",
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 39,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "Prometheus",
          "value": "Prometheus"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 1 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(flask_http_requests_total[5m]))",
          "legendFormat": "requests/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "id": 3,
      "title": "Request Rate by Status Code",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 1 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(flask_http_requests_total[5m])) by (status_code)",
          "legendFormat": "{{status_code}}",
          "refId": "A"
        }
      ],
      "options": {
        "stacking": { "mode": "normal" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "id": 4,
      "title": "P95 Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(flask_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 5,
      "title": "Error Rate (%)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(flask_http_requests_total{status_code=~\"4..|5..\"}[5m])) / sum(rate(flask_http_requests_total[5m])) * 100",
          "legendFormat": "error %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Latency Breakdown",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "id": 7,
      "title": "Latency Percentiles (P50 / P95 / P99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(flask_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(flask_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(flask_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 8,
      "title": "Latency by Endpoint (Top 10 - P95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.95, sum(rate(flask_http_request_duration_seconds_bucket[5m])) by (le, endpoint)))",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "id": 9,
      "title": "Business Metrics",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false
    },
    {
      "id": 10,
      "title": "User Registrations (24h)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 19 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(careerconnect_user_registrations_total[24h]))",
          "legendFormat": "registrations",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 11,
      "title": "User Logins (1h)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 19 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(careerconnect_user_logins_total[1h]))",
          "legendFormat": "logins",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      }
    },
    {
      "id": 12,
      "title": "Posts Created",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 4, "x": 8, "y": 19 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "rate(careerconnect_posts_created_total[5m])",
          "legendFormat": "posts/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "id": 13,
      "title": "Comments Created",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 19 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "rate(careerconnect_comments_created_total[5m])",
          "legendFormat": "comments/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "id": 14,
      "title": "Likes Given",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 4, "x": 16, "y": 19 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "rate(careerconnect_likes_total[5m])",
          "legendFormat": "likes/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "id": 15,
      "title": "Chats Sent",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 4, "x": 20, "y": 19 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "rate(careerconnect_chats_sent_total[5m])",
          "legendFormat": "chats/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      }
    },
    {
      "id": 16,
      "title": "Endpoint Breakdown",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "collapsed": false
    },
    {
      "id": 17,
      "title": "Top Endpoints by Request Count",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "topk(10, sum(rate(flask_http_requests_total[5m])) by (endpoint))",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient"
      }
    },
    {
      "id": 18,
      "title": "Slowest Endpoints (P95)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.95, sum(rate(flask_http_request_duration_seconds_bucket[5m])) by (le, endpoint)))",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient"
      }
    }
  ]
}
